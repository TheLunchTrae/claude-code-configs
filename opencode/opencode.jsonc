{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git commit*": "ask",
      "git push*": "ask",
      "sudo*": "ask",
      "git branch -D*": "deny",
      "git clean -f*": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git reset --hard*": "deny",
      "rm -rf*": "deny"
    },
    "edit": {
      "*": "ask",
      "~/.opencode-artifacts/**": "allow"
    }
  }
}
