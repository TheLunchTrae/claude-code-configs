{
  // OpenCode configuration
  // Migrated from Claude Code settings.json
  // See skills/opencode-sync/SKILL.md for the full CC -> OpenCode mapping
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    // Ask before committing or pushing; deny destructive operations.
    // Rules are evaluated left-to-right; last matching rule wins.
    "bash(git commit*)": "ask",
    "bash(git push*)": "ask",
    "bash(sudo*)": "ask",
    "bash(git push --force*)": "deny",
    "bash(git push -f*)": "deny",
    "bash(git branch -D*)": "deny",
    "bash(git clean -f*)": "deny",
    "bash(git reset --hard*)": "deny",
    "bash(rm -rf*)": "deny"
  }
}
