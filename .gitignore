# Credentials - NEVER commit (contains OAuth tokens)
.credentials.json


# Conversation history
history.jsonl

# Runtime caches and generated data
cache/
backups/
file-history/
downloads/
session-env/
sessions/
shell-snapshots/
tasks/

# Claude Code plugins cache (root-level only — reinstallable; enabled plugins are captured in settings.json).
