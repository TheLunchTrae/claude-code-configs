{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "{file:.config-dir}/instructions/caveman.md",
    "{file:.config-dir}/instructions/general.md",
    "{file:.config-dir}/instructions/security.md",
    "{file:.config-dir}/instructions/accuracy.md",
    "{file:.config-dir}/instructions/coding-style.md",
    "{file:.config-dir}/instructions/code-review.md",
    "{file:.config-dir}/instructions/testing.md",
    "{file:.config-dir}/instructions/patterns.md",
    "{file:.config-dir}/instructions/agents.md"
  ],
  "permission": {
    "bash": {
      "git commit*": "ask",
      "git push*": "ask",
      "sudo*": "ask",
      "git branch -D*": "deny",
      "git clean -f*": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git reset --hard*": "deny",
      "rm -rf*": "deny"
    },
    "edit": {
      "*": "ask",
      "~/.opencode-data/**": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/.opencode-data/**": "allow"
    },
    "task": {
      "*": "allow"
    }
  }
}
