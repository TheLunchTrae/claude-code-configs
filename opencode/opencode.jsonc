{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "instructions/general.md",
    "instructions/security.md",
    "instructions/accuracy.md",
    "instructions/git-workflow.md",
    "instructions/code-review.md",
    "instructions/coding-style.md",
    "instructions/development-workflow.md",
    "instructions/testing.md",
    "instructions/patterns.md",
    "instructions/performance.md"
  ],
  "permission": {
    "bash": {
      "git commit*": "ask",
      "git push*": "ask",
      "sudo*": "ask",
      "git branch -D*": "deny",
      "git clean -f*": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git reset --hard*": "deny",
      "rm -rf*": "deny"
    },
    "edit": {
      "*": "ask",
      "~/.opencode-artifacts/**": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/.opencode-artifacts/**": "allow"
    }
  }
}
